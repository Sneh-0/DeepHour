# Server
PORT=4000

# Option A — Supabase (preferred): Project Settings → Database → Connection string (URI)
# Use the Session pooler (port 5432) or Transaction pooler (port 6543) string.
DATABASE_URL=postgresql://postgres.your-project-ref:your_db_password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Option B — local PostgreSQL (used only if DATABASE_URL is unset)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deep_work_tracker
DB_USER=postgres
DB_PASSWORD=your_db_password

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# Comma-separated allowed origins for CORS (optional; defaults cover local dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:5001
